@startuml
skinparam linetype ortho

skinparam nodesep 150
skinparam ranksep 100

top to bottom direction


class Simulator {
 + Detector detector
 + Source[1..*] sources
 + Event collect_event()
 - Emission get_random_emission()
}

together {
 struct Vector2 <<DataType>> {
  + float x
  + float y
 }

 struct Vector3 <<DataType>> {
  + float x
  + float y
  + float z
 }
}

'Simulator -[hidden]> Vector2
'Vector2 -[hidden]> Vector3
'
Simulator *-- "1" Detector
Simulator *-- "1..*" Source

Simulator -[hidden]down- Geometry

abstract class Geometry {
 + Vector3 origin
 + {abstract} bool is_inside(position: Vector3)
}

together {
 class RectangularPrism {
  + Vector3 size
  + bool is_inside(position: Vector3)
 }

 class Cylinder {
  + radius: float
  + height: float
  + bool is_inside(position: Vector3)
 }
}

Cylinder -up-|> Geometry
RectangularPrism -up-|> Geometry

together {
class Detector {
 + Geometry geometry
 + int num_channels
 + float[1..*] channel_widths
 + float channel_spacing
 + float channel_start_position
 + String channel_direction
 + float threshold
 + float drift_velocity
 + float electron_lifetime_ms
 + float channel_resolution
 + int signal_width
 + Event process_emission(emission: Emission, position: Vector3)
}

struct Event {
 + int[1..*] channels
 + float[1..*] amplitudes
 + Emission emission
}
}

Detector -r-> Geometry
Source -l-> Geometry

together {
class Source {
 + Geometry geometry
 + DecayBranch[1..*] decay_branches
 - DecayBranch get_random_decay_branch()
 + Emission[1..*] get_random_decay_emissions()
 + Vector3 get_emission_position(emission: Emission)
}

class Emission {
 + float energy_mev
 + float interaction_distance
 + Map<String, float> internal_conversion_coeffs
 + bool is_corrected
 + String type
 + Emission get_corrected_emission(shell_binding_energies: Map<String, float>)
}

class DecayBranch {
 + float probabililty
 + Emission[1..*] emissions
 + Emission[1..*] get_corrected_emission(shell_binding_energies: Map<String, float>)
}

}

Source "1" *-- "1..*" DecayBranch
DecayBranch "1" *-- "1..*" Emission

Detector -d-> Event

@enduml
